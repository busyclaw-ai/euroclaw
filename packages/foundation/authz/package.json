{
	"name": "@euroclaw/authz",
	"version": "0.0.0",
	"type": "module",
	"description": "The euroclaw authz toolkit: the policy-plugin scaffolding (engine → deny-by-default gate) and the authorization-model builder. Protocol lives in @euroclaw/contracts; engines live in @euroclaw/policy-*.",
	"license": "MIT",
	"author": "Konstantin Ponomarev",
	"homepage": "https://github.com/euroclaw-sh/euroclaw#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/euroclaw-sh/euroclaw.git",
		"directory": "packages/foundation/authz"
	},
	"bugs": {
		"url": "https://github.com/euroclaw-sh/euroclaw/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsc",
		"test": "vitest run tests",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@euroclaw/contracts": "workspace:*",
		"@euroclaw/errors": "workspace:*",
		"arktype": "2.2.0"
	}
}
